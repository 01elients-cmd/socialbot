# ── Base de datos PostgreSQL ──
# URL completa de conexión (Render, Supabase, Railway, local, etc.)
DATABASE_URL=postgresql://usuario:password@host:5432/socialbot

# ── OpenRouter IA ──
# Obtén tu clave en https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ── Telegram Bot ──
# Token del bot (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=

# ID de empresa que recibe mensajes de Telegram (por defecto: 5)
TELEGRAM_EMPRESA_ID=5

# ── Entorno ──
# Usar 'production' en Render / Railway para habilitar SSL en PostgreSQL
NODE_ENV=development

# ── Puerto (opcional, default: 5000) ──
PORT=5000
